{
  "name": "Gaboom DriveOS",
  "description": "Django SaaS car rental management system",
  "keywords": ["django", "saas", "car-rental", "management"],
  "website": "https://gaboomdriveos.gaboomholding.com",
  "repository": "https://github.com/your-repo/gaboom-driveos",
  "logo": "https://gaboomdriveos.gaboomholding.com/static/logo.png",
  "scripts": {
    "dokku": {
      "predeploy": "python manage.py migrate --noinput && python manage.py collectstatic --noinput",
      "postdeploy": "python manage.py check --deploy"
    }
  },
  "healthchecks": {
    "web": {
      "path": "/health/",
      "interval": 10,
      "timeout": 5,
      "retries": 3
    }
  },
  "formation": {
    "web": {
      "quantity": 1,
      "size": "1x"
    }
  },
  "env": {
    "DJANGO_SETTINGS_MODULE": "config.settings",
    "DJANGO_DEBUG": "0",
    "PYTHONUNBUFFERED": "1"
  },
  "addons": [
    "dokku-postgres",
    "dokku-redis"
  ],
  "buildpacks": [
    "https://github.com/heroku/heroku-buildpack-python.git"
  ]
}
