# ══════════════════════════════════════════════════════════════
# Gaboom DriveOS — Variables d'environnement
# ══════════════════════════════════════════════════════════════
# Copier ce fichier vers .env et remplir les valeurs.
# NE JAMAIS commiter le fichier .env (il est dans .gitignore).
# En production, définir ces variables via le panel d'hébergement.
# ══════════════════════════════════════════════════════════════

# Django
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL (optionnel — si vide, SQLite est utilisé)
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=gaboom_driveos
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# Email — Brevo (ex-Sendinblue)
BREVO_API_KEY=change-me
DEFAULT_FROM_EMAIL=change-me
SERVER_EMAIL=change-me

# Sécurité production (DEBUG=0)
CSRF_TRUSTED_ORIGINS=
