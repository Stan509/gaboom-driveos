msgid "Agences illimitées"
msgstr "Agencias ilimitadas"

msgid "agence"
msgstr "agencia"

msgid "Utilisateurs illimités"
msgstr "Usuarios ilimitados"

msgid "utilisateur"
msgstr "usuario"

msgid "Véhicules illimités"
msgstr "Vehículos ilimitados"

msgid "véhicule"
msgstr "vehículo"

msgid "J'accepte les"
msgstr "Acepto los"

msgid "Conditions d'utilisation"
msgstr "Términos de uso"

msgid "et la"
msgstr "y la"

msgid "Politique de confidentialité"
msgstr "Política de privacidad"

msgid "Essai gratuit · Sans carte bancaire"
msgstr "Prueba gratis · Sin tarjeta"

msgid "Déjà un compte ?"
msgstr "¿Ya tienes una cuenta?"

msgid "Création…"
msgstr "Creando…"

msgid "Le nom de l'agence est requis."
msgstr "El nombre de la agencia es obligatorio."

msgid "Identifiant URL de votre agence. Généré automatiquement si vide."
msgstr "Identificador URL de tu agencia. Se genera automáticamente si está vacío."

msgid "Veuillez choisir un plan."
msgstr "Por favor elige un plan."

msgid "L'email est requis."
msgstr "El correo electrónico es obligatorio."

msgid "Email invalide."
msgstr "Correo electrónico inválido."

msgid "Le mot de passe est requis."
msgstr "La contraseña es obligatoria."

msgid "Confirmez le mot de passe."
msgstr "Confirma la contraseña."

msgid "Vous devez accepter les conditions d'utilisation."
msgstr "Debes aceptar los términos de uso."

msgid "Le slug contient des caractères invalides."
msgstr "El slug contiene caracteres inválidos."

msgid "Ce lien est déjà utilisé, choisissez-en un autre."
msgstr "Este enlace ya está en uso, elige otro."

msgid "Un compte avec cet email existe déjà."
msgstr "Ya existe una cuenta con este correo electrónico."

msgid "Les mots de passe ne correspondent pas."
msgstr "Las contraseñas no coinciden."

msgid "Veuillez choisir un plan valide."
msgstr "Por favor elige un plan válido."
