msgstr "Suscripción"

msgid "Mon compte"
msgstr "Mi cuenta"

msgid "SuperAdmin"
msgstr "SuperAdmin"

msgid "Multi-agence natif"
msgstr "Multiagencia nativo"

msgid "Client retention intégré"
msgstr "Retención de clientes integrada"

msgid "Le système d'exploitation pour agences de location modernes."
msgstr "El sistema operativo para agencias de alquiler modernas."

msgid "Gérez votre flotte, automatisez vos contrats, encaissez en ligne et fidélisez vos clients — le tout depuis un seul dashboard."
msgstr "Gestiona tu flota, automatiza contratos, cobra en línea y fideliza clientes — todo desde un solo panel."

msgid "Voir la démo"
msgstr "Ver la demo"

msgid "Aucune carte bancaire requise. Activation immédiate."
msgstr "No se requiere tarjeta. Activación inmediata."

msgid "En location"
msgstr "En alquiler"

msgid "Disponible"
msgstr "Disponible"

msgid "Opérationnel"
msgstr "Operativo"

msgid "Mis à jour il y a 2 min"
msgstr "Actualizado hace 2 min"

msgid "Problème"
msgstr "Problema"

msgid "Gestion papier, pertes, retards"
msgstr "Gestión en papel, pérdidas, retrasos"

msgid "Tableurs dispersés, données incohérentes"
msgstr "Hojas de cálculo dispersas, datos incoherentes"

msgid "Véhicules mal suivis, inspections oubliées"
msgstr "Vehículos mal controlados, inspecciones olvidadas"

msgid "Aucune visibilité sur la rentabilité réelle"
msgstr "Sin visibilidad de la rentabilidad real"

msgid "Communication WhatsApp, zéro traçabilité"
msgstr "Comunicación por WhatsApp, cero trazabilidad"

msgid "Solution"
msgstr "Solución"

msgid "Tout centralisé, en temps réel"
msgstr "Todo centralizado, en tiempo real"

msgid "Un cockpit unique pour toute la flotte"
msgstr "Un único panel para toda la flota"

msgid "Tracking, inspections, maintenance planifiée"
msgstr "Seguimiento, inspecciones y mantenimiento planificado"

msgid "Analytics et KPIs orientés décision"
msgstr "Analítica y KPIs orientados a decisiones"

msgid "Équipe structurée, rôles, permissions"
msgstr "Equipo estructurado, roles y permisos"

msgid "Augmente tes revenus sans augmenter ta flotte"
msgstr "Aumenta tus ingresos sin aumentar tu flota"

msgid "Optimise chaque véhicule, chaque client, chaque euro."
msgstr "Optimiza cada vehículo, cada cliente y cada euro."

msgid "Optimisation taux d'occupation"
msgstr "Optimización de la ocupación"

msgid "Maximise le temps de location de chaque véhicule."
msgstr "Maximiza el tiempo de alquiler de cada vehículo."

msgid "Recommandations intelligentes"
msgstr "Recomendaciones inteligentes"

msgid "Suggestions basées sur l'historique et la saisonnalité."
msgstr "Sugerencias basadas en el historial y la estacionalidad."

msgid "Rappels de retour"
msgstr "Recordatorios de devolución"

msgid "Notifications automatiques pour réduire les retards."
msgstr "Notificaciones automáticas para reducir retrasos."

msgid "Relances clients inactifs"
msgstr "Reactivación de clientes inactivos"

msgid "Réactive les anciens clients avec des offres ciblées."
msgstr "Reactivar antiguos clientes con ofertas dirigidas."

msgid "Tout ce qu'il faut pour scaler"
msgstr "Todo lo necesario para escalar"

msgid "Chaque module est pensé pour fonctionner seul et s'intégrer au reste."
msgstr "Cada módulo está diseñado para funcionar solo e integrarse con el resto."

msgid "Contrats & réservations"
msgstr "Contratos y reservas"

msgid "Crée, signe et archive tes contrats. Suivi du cycle complet de chaque location."
msgstr "Crea, firma y archiva tus contratos. Seguimiento del ciclo completo de cada alquiler."

msgid "Inspection & photos"
msgstr "Inspección y fotos"

msgid "Checklists visuelles, photos avant/après, historique complet de l'état véhicule."
msgstr "Listas visuales, fotos antes/después, historial completo del estado del vehículo."

msgid "Maintenance intelligente"
msgstr "Mantenimiento inteligente"

msgid "Planifie les entretiens, reçois des alertes, réduis les immobilisations."
msgstr "Planifica mantenimientos, recibe alertas y reduce inmovilizaciones."

msgid "GPS tracking & géofencing"
msgstr "Seguimiento GPS y geocercas"

msgid "Localise ta flotte, définis des zones, reçois des alertes de sortie en temps réel."
msgstr "Localiza tu flota, define zonas y recibe alertas de salida en tiempo real."

msgid "Analytics rentabilité"
msgstr "Analítica de rentabilidad"

msgid "KPIs par véhicule, taux d'occupation, revenus. Décide avec de la data, pas au feeling."
msgstr "KPIs por vehículo, ocupación e ingresos. Decide con datos, no por intuición."

msgid "Équipe & permissions"
msgstr "Equipo y permisos"

msgid "Owner, Admin, Staff — chaque rôle a ses droits. Multi-agence natif."
msgstr "Owner, Admin, Staff — cada rol tiene sus derechos. Multiagencia nativo."

msgid "Fidélise tes clients automatiquement"
msgstr "Fideliza a tus clientes automáticamente"

msgid "Ne perds plus jamais un ancien client. Gaboom DriveOS t'aide à garder le contact et à maximiser la valeur de chaque location."
msgstr "No vuelvas a perder un cliente antiguo. Gaboom DriveOS te ayuda a mantener el contacto y maximizar el valor de cada alquiler."

msgid "Historique client complet"
msgstr "Historial completo del cliente"

msgid "Fiche client avec historique des locations, préférences et notes."
msgstr "Ficha del cliente con historial de alquileres, preferencias y notas."

msgid "Relances automatiques"
msgstr "Seguimientos automáticos"

msgid "Relance automatique après restitution pour rebooker rapidement."
msgstr "Seguimiento automático tras la devolución para reservar de nuevo rápidamente."

msgid "Notifications promotions"
msgstr "Notificaciones de promociones"

msgid "Offres spéciales ciblées pour anciens clients et périodes creuses."
msgstr "Ofertas especiales dirigidas para clientes antiguos y periodos de baja demanda."

msgid "Base CRM intégrée"
msgstr "Base CRM integrada"

msgid "Base de données centralisée de tous vos clients et interactions."
msgstr "Base de datos centralizada de todos tus clientes e interacciones."

msgid "Ta flotte est protégée"
msgstr "Tu flota está protegida"

msgid "Isolation stricte des données par agence. Architecture multi-tenant sécurisée. Logs d'audit prêts pour conformité."
msgstr "Aislamiento estricto de datos por agencia. Arquitectura multi‑tenant segura. Registros de auditoría listos para cumplimiento."

msgid "Isolation par agence"
msgstr "Aislamiento por agencia"

msgid "Chaque agence est un silo étanche. Aucun accès croisé possible entre les données."
msgstr "Cada agencia es un silo aislado. No hay acceso cruzado entre datos."

msgid "Architecture multi-tenant"
msgstr "Arquitectura multi‑tenant"

msgid "Séparation stricte au niveau base de données, middleware et permissions."
msgstr "Separación estricta en base de datos, middleware y permisos."

msgid "Logs d'audit"
msgstr "Registros de auditoría"

msgid "Traçabilité complète des actions. Prêt pour conformité et audits."
msgstr "Trazabilidad completa de acciones. Listo para cumplimiento y auditorías."

msgid "Multi-agence, équipe complète."
msgstr "Multiagencia, equipo completo."

msgid "Multi-agence"
msgstr "Multiagencia"

msgid "15 utilisateurs"
msgstr "15 usuarios"

msgid "Véhicules illimités"
msgstr "Vehículos ilimitados"

msgid "Support prioritaire"
msgstr "Soporte prioritario"

msgid "Sur mesure, accompagnement dédié."
msgstr "A medida, acompañamiento dedicado."

msgid "Tout Pro inclus"
msgstr "Todo lo de Pro incluido"

msgid "Workflows custom"
msgstr "Workflows personalizados"

msgid "Intégrations avancées"
msgstr "Integraciones avanzadas"

msgid "Onboarding personnalisé"
msgstr "Onboarding personalizado"

msgid "SLA garanti"
msgstr "SLA garantizado"

msgid "Questions fréquentes"
msgstr "Preguntas frecuentes"

msgid "Tout ce que tu dois savoir avant de commencer."
msgstr "Todo lo que debes saber antes de empezar."

msgid "Est-ce vraiment multi-agence ?"
msgstr "¿Es realmente multiagencia?"

msgid "Oui. Chaque utilisateur est rattaché à une agence. Les données sont strictement séparées. Tu peux gérer plusieurs agences depuis un seul compte owner."
msgstr "Sí. Cada usuario está ligado a una agencia. Los datos están estrictamente separados. Puedes gestionar varias agencias desde una sola cuenta owner."

msgid "Puis-je essayer gratuitement ?"
msgstr "¿Puedo probar gratis?"

msgid "Absolument. Tous les plans incluent un essai gratuit sans carte bancaire. Tu testes, tu décides."
msgstr "Absolutamente. Todos los planes incluyen prueba gratis sin tarjeta. Tú pruebas, tú decides."

msgid "Le paiement Stripe est-il inclus ?"
msgstr "¿Incluye pagos con Stripe?"

msgid "Oui. Stripe est intégré pour permettre à vos clients de payer leurs réservations en ligne directement sur votre site public. Vous connectez votre compte Stripe et recevez les paiements directement. Gaboom DriveOS ne prend pas le contrôle de vos fonds."
msgstr "Sí. Stripe está integrado para que tus clientes paguen sus reservas en línea directamente en tu sitio público. Conectas tu cuenta Stripe y recibes los pagos directamente. Gaboom DriveOS no controla tus fondos."

msgid "Mes clients peuvent-ils réserver en ligne ?"
msgstr "¿Pueden mis clientes reservar en línea?"

msgid "Oui. Chaque agence dispose d'un site public avec catalogue et formulaire de réservation, activable en un clic."
msgstr "Sí. Cada agencia dispone de un sitio público con catálogo y formulario de reservas, activable con un clic."

msgid "Le GPS est-il intégré ?"
msgstr "¿Está integrado el GPS?"

msgid "Le module GPS tracking avec géofencing est prévu dans le plan Pro. L'architecture supporte déjà les fournisseurs tiers."
msgstr "El módulo de seguimiento GPS con geocercas está en el plan Pro. La arquitectura ya soporta proveedores externos."

msgid "Puis-je personnaliser le site de mon agence ?"
msgstr "¿Puedo personalizar el sitio de mi agencia?"

msgid "Oui. Couleurs, thème, activation/désactivation, mode maintenance — tout est configurable depuis le dashboard."
msgstr "Sí. Colores, tema, activar/desactivar, modo mantenimiento — todo es configurable desde el panel."

msgid "Prêt à piloter ta flotte ?"
msgstr "¿Listo para dirigir tu flota?"

msgid "Rejoins les agences qui passent au niveau supérieur."
msgstr "Únete a las agencias que suben de nivel."

msgid "Démarrer maintenant"
msgstr "Empezar ahora"

msgid "Gratuit · Sans engagement · En 30 secondes"
msgstr "Gratis · Sin compromiso · En 30 segundos"

msgid "Produit"
msgstr "Producto"

msgid "Créer une agence"
msgstr "Crear una agencia"

msgid "Portail client non disponible"
msgstr "Portal de cliente no disponible"

msgid "Cette fonctionnalité n'est pas incluse dans votre plan actuel."
msgstr "Esta función no está incluida en su plan actual."

msgid "Le portail client permet à vos clients de suivre leurs réservations, signer leurs contrats et gérer leur profil en toute autonomie."
msgstr "El portal de clientes permite a sus clientes seguir sus reservas, firmar sus contratos y gestionar su perfil de forma autónoma."

msgid "Avec le portail client, vos clients peuvent :"
msgstr "Con el portal de clientes, sus clientes pueden:"

msgid "Suivre leurs réservations en temps réel"
msgstr "Seguir sus reservas en tiempo real"

msgid "Signer numériquement leurs contrats"
msgstr "Firmar sus contratos digitalmente"

msgid "Consulter leurs documents"
msgstr "Consultar sus documentos"

msgid "Communiquer directement avec vous"
msgstr "Comunicarse directamente con usted"

msgid "L'équipe Gaboom s'excuse pour la gêne occasionnée."
msgstr "El equipo Gaboom se disculpa por las molestias ocasionadas."

msgid "Contactez-nous pour mettre à niveau votre abonnement et débloquer cette fonctionnalité."
msgstr "Contáctenos para actualizar su suscripción y desbloquear esta función."

